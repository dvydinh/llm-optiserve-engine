# Model configuration
MODEL_NAME_OR_PATH=TheBloke/Llama-2-7B-Chat-AWQ
QUANTIZATION_METHOD=awq

# vLLM engine settings
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.85
MAX_MODEL_LEN=4096
DTYPE=auto

# Server configuration
HOST=0.0.0.0
PORT=8000

# Quantizer settings (used when running quantizer.py)
SOURCE_MODEL_PATH=meta-llama/Llama-2-7B-chat-hf
QUANTIZED_OUTPUT_PATH=./models/llama-2-7b-chat-awq
AWQ_GROUP_SIZE=128
AWQ_ZERO_POINT=true
AWQ_VERSION=gemm
CALIBRATION_SIZE=128
